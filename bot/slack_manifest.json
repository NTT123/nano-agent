{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "nano-agent",
    "description": "Agentic coding assistant (nano-agent) running in Slack.",
    "long_description": "nano-agent Slack bot: an AI assistant with tools for reading files, running commands, editing code, browsing the web, and more. Responds to mentions in channels and to DMs. Messages are queued per channel/thread and processed by a background agent loop; slash commands inspect and control the queue. Uses Socket Mode — no public HTTP endpoint required.",
    "background_color": "#1D4ED8"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "nano-agent",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/clear",
        "description": "Clear conversation history in this channel/thread",
        "should_escape": false
      },
      {
        "command": "/queue",
        "description": "Show queued user messages",
        "should_escape": false
      },
      {
        "command": "/cd",
        "description": "Change the bot's working directory",
        "usage_hint": "<path>",
        "should_escape": false
      },
      {
        "command": "/cwd",
        "description": "Show the bot's current working directory",
        "should_escape": false
      },
      {
        "command": "/thread",
        "description": "Start a new conversation in a thread",
        "usage_hint": "<topic>",
        "should_escape": false
      },
      {
        "command": "/renew",
        "description": "Re-run OAuth login for the active LLM provider",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "files:read",
        "files:write",
        "users:read",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
